# Integration test configuration
# You can use absolute paths or filenames relative to TEST_IMAGE_DIR.
TEST_IMAGE_DIR=./testdata

# Comma-separated image file lists for each endpoint.
TEST_IMAGE_PARTS=parts-a.jpg,parts-b.jpg
TEST_IMAGE_SETS=sets-a.jpg
TEST_IMAGE_MINIFIGS=minifigs-a.jpg

# Comma-separated expected item counts matching each image list by position.
TEST_EXPECTED_PARTS=2,1
TEST_EXPECTED_SETS=1
TEST_EXPECTED_MINIFIGS=1

